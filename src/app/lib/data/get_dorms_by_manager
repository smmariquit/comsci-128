import { supabase } from '../supabase';

export const getManagedDorms = async (managerAccountNumber: number) => {
  const { data: manager, error: managerError } = await supabase
    .from('manager')
    .select('account_number, manager_type')
    .eq('account_number', managerAccountNumber)
    .single();

  if (managerError || !manager) throw new Error('Unauthorized');

  const { data, error } = await supabase
    .from('housing')
    .select(`
      housing_id,
      housing_name,

      room (
        room_id,
        room_type,
        maximum_occupants,

        student_accommodation_history (
          movein_date,
          moveout_date,

          student_academic (
            account_number,
            degree_program,
            standing,
            status
          )
        )
      )
    `)
    .eq('manager_account_number', managerAccountNumber)
    .eq('is_deleted', false);

  if (error) throw error;

  return data;
};