import { supabase } from '../supabase';

export const getManagerDorms = async (manager_id: number) => {
    const { data, error } = await supabase
      .from('room')
      .select(`
        room_id,
        room_type,
        maximum_occupants,
        housing!inner (
          manager_id
        ),
        student_accommodation_history (
          account_number,
          actual_move_out_date,
          student (
            student_id,
            name
          )
        )
      `)
      .eq('housing.manager_id', manager_id)
      .eq('is_deleted', false);
  
    if (error) throw error;
  
    return data.map((room: any) => {
      const occupants = room.student_accommodation_history
        ?.filter((h: any) => h.actual_move_out_date === null)
        ?.map((h: any) => ({
          student_id: h.student?.student_id,
          name: h.student?.name
        })) || [];
  
      return {
        room_id: room.room_id,
        room_type: room.room_type,
        occupants,
        available_slots: room.maximum_occupants - occupants.length
      };
    });
  };


