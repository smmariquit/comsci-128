  export const getAllTenants = async () => {
    const { data, error } = await supabase
      .from('student_accommodation_history')
      .select(`
        history_id,
        move_in_date,
        expected_move_out_date,
        actual_move_out_date,
  
        student_academic (
          account_number,
          student_number,
          degree_program,
          standing,
          status
        ),
  
        room (
          room_id,
          room_type,
          housing (
            housing_name
          )
        )
      `);
  
    if (error) throw error;
  
    return data.map((entry: any) => ({
      account_number: entry.student_academic?.account_number,
      student_number: entry.student_academic?.student_number,
      degree_program: entry.student_academic?.degree_program,
      standing: entry.student_academic?.standing,
      academic_status: entry.student_academic?.status,
  
      room_id: entry.room?.room_id,
      room_type: entry.room?.room_type,
      housing_name: entry.room?.housing?.housing_name,
  
      start_of_stay: entry.move_in_date,
      end_of_stay: entry.actual_move_out_date || entry.expected_move_out_date
    }));
  };

  export const getStudentsByRoom = async (room_id: number) => {
    const { data, error } = await supabase
      .from('student_accommodation_history')
      .select(`
        move_in_date,
        actual_move_out_date,
  
        student_academic (
          account_number,
          student_number,
          degree_program,
          standing,
          status
        )
      `)
      .eq('room_id', room_id)
      .is('actual_move_out_date', null); // only current occupants
  
    if (error) throw error;
  
    return data.map((entry: any) => ({
      account_number: entry.student_academic?.account_number,
      student_number: entry.student_academic?.student_number,
      degree_program: entry.student_academic?.degree_program,
      standing: entry.student_academic?.standing,
      academic_status: entry.student_academic?.status,
  
      move_in_date: entry.move_in_date
    }));
  };