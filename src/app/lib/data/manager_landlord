import { supabase } from '../supabase';

export const getManagerDormsFormatted = async (manager_id: number) => {
    const { data, error } = await supabase
      .from('room')
      .select(`
        room_id,
        room_type,
        housing (
          manager_id
        ),
        student_accommodation_history (
          status,
          student (
            student_id,
            name
          )
        )
      `);
  
    if (error) throw error;
  
    const filtered = data.filter(
      (room: any) => room.housing?.manager_id === manager_id
    );
  
    return filtered.map((room: any) => {
      const occupants = room.student_accommodation_history
        ?.filter((h: any) => h.status === "Active")
        ?.map((h: any) => ({
          student_id: h.student?.student_id,
          name: h.student?.name
        })) || [];
  
      const availableSlots = room.capacity - occupants.length;
  
      return {
        room_id: room.room_id,
        room_type: room.room_type,
        occupants,
        available_slots: availableSlots
      };
    });
  };


export const getDetailsRoomByHousingId = async (housing_id: number) => {
    const { data, error } = await supabase
      .from('room')
      .select(`
        room_id,
        room_type,
  
        student_accommodation_history (
          student_id,
          status,
          student (
            name
          )
        )
      `)
      .eq('housing_id', housing_id);
  
    if (error) throw error;
  
    
    return data.map((room: any) => {
      const activeOccupants = room.student_accommodation_history
        .filter((s: any) => s.status === 'Active');
  
      const occupants = activeOccupants.map((s: any) => ({
        student_id: s.student_id,
        name: s.student?.name
      }));
  
      const occupied = occupants.length;
      const available_slots = room.capacity - occupied;
  
      return {
        room_id: room.room_id,
        room_type: room.room_type,
        occupants,            // list of occupants
        available_slots       
      };
    });
  };

  export const studentsPerDorm = async (dorm_id: number) => {
    const { data, error } = await supabase
      .from('student_accommodation_history')
      .select(`
        student_id,
        status,
        student (
          name
        )
      `)
      .eq('dorm_id', dorm_id)
      .eq('status', 'Active'); 
  
    if (error) throw error;
  
    return data.map((s: any) => ({
      student_id: s.student_id,
      name: s.student?.name
    }));
  };